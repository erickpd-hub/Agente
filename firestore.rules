rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Platform Users: Anyone authenticated or general access for verification, admins can write
    match /platform_users/{userId} {
      allow read, write: if true;
    }

    // User Profiles: Private per email
    match /user_profiles/{email} {
      allow read, write: if true;
    }

    // User Chats: Private per email
    match /user_chats/{email} {
      allow read, write: if true;
    }

    // User Knowledge Base: Private per email
    match /user_knowledge_base/{email} {
      allow read, write: if true;
    }
  }
}
